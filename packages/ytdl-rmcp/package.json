{
  "name": "ytdl-rmcp",
  "version": "1.0.3",
  "description": "Node launcher for the ytdl-rmcp Rust MCP server and rytdl CLI for yt-dlp media workflows.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jmagar/rytdl.git",
    "directory": "packages/ytdl-rmcp"
  },
  "bin": {
    "ytdl-rmcp": "bin/rytdl.js",
    "rytdl": "bin/rytdl.js"
  },
  "files": [
    "bin/",
    "lib/",
    "scripts/",
    "README.md",
    "LICENSE*",
    "package.json"
  ],
  "scripts": {
    "prepack": "node scripts/sync-readme.js",
    "postinstall": "node scripts/install.js",
    "test": "node --test",
    "check": "node --check bin/rytdl.js && node --check scripts/install.js && node --check lib/platform.js && node --check scripts/sync-readme.js && node --check scripts/check-package.js && node scripts/check-package.js",
    "prepublishOnly": "node scripts/check-package.js --release"
  },
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://github.com/jmagar/rytdl#readme",
  "bugs": {
    "url": "https://github.com/jmagar/rytdl/issues"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "rmcp",
    "rust",
    "cli",
    "yt-dlp",
    "youtube",
    "media-downloader",
    "ffmpeg",
    "plex",
    "metadata",
    "ssh",
    "rclone",
    "homelab",
    "claude-code",
    "codex",
    "gemini",
    "mcp-apps"
  ],
  "mcpName": "ai.dinglebear/ytdl-rmcp",
  "binaryVersion": "1.0.1",
  "author": {
    "name": "dinglebear.ai",
    "url": "https://dinglebear.ai"
  }
}
